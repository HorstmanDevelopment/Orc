{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Orc.Cli",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Orc.Cli/bin/Debug/net10.0/orc.dll",
            "cwd": "${workspaceFolder}/Orc.Cli",
            "console": "externalTerminal",
            "stopAtEntry": false,
            "justMyCode": false
        }
    ]
}
