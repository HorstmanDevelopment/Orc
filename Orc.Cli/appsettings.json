{
  "Workspace": {
    "Root": "./workspace"
  },
  "Claude": {
    "BinaryHint": null,
    "PermissionMode": "acceptEdits",
    "Timeout": "00:30:00"
  },
  "Orchitect": {
    "MaxModificationsPerDay": 5,
    "MaxModificationsPerRepoPerDay": 2,
    "ConsecutiveFailureLimit": 2,
    "ReadOnlyTools": ["Read", "Glob", "Grep"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
