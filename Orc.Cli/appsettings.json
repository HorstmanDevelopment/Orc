{
  "Workspace": {
    "Root": "./workspace"
  },
  "Claude": {
    "BinaryHint": null,
    "PermissionMode": "acceptEdits",
    "Timeout": "00:30:00"
  },
  "Orchitect": {
    "MaxModificationsPerDay": 5,
    "MaxModificationsPerRepoPerDay": 2,
    "ConsecutiveFailureLimit": 2,
    "AnalysisTools": ["Read", "Glob", "Grep", "Write(claude_output/**)"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  }
}
